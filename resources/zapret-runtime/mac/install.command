#!/bin/bash
#
# install.command — двойной клик для установки без терминала.
# Скомпилирует Zapret.app и откроет его. Дальше — кнопка «Установить».
#
# Если macOS ругается «не удаётся открыть, неизвестный разработчик» —
# кликни по файлу ПРАВОЙ кнопкой → «Открыть» → «Открыть».

cd "$(dirname "$0")" || exit 1

echo "============================================"
echo "  Zapret для macOS — установка"
echo "============================================"
echo

# На всякий случай снимаем карантин с скриптов рядом.
xattr -dr com.apple.quarantine . 2>/dev/null || true

echo "[1/2] Собираю Zapret.app..."
/bin/bash ./build-app.sh || {
    echo
    echo "[x] Не удалось собрать приложение. Напиши об ошибке выше."
    echo "Окно можно закрыть."
    exit 1
}

echo
echo "[2/2] Открываю Zapret.app."
echo
echo ">>> В окне приложения нажми «🔄 Установить / Переустановить»."
echo ">>> Введи пароль администратора один раз — дальше включение/выключение"
echo ">>> и смена стратегии будут уже без пароля."
echo
open ./Zapret.app

echo "Готово. Это окно терминала можно закрыть."
